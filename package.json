{
  "name": "devops-technical-assessment",
  "version": "1.0.0",
  "private": true,
  "description": "Quality tooling for a two-site Docker, Nginx, and GitHub Actions assessment.",
  "scripts": {
    "format:check": "prettier --check .",
    "lint:css": "stylelint \"site*/**/*.css\"",
    "lint:html": "html-validate \"site*/**/*.html\"",
    "lint:js": "eslint \"site*/**/*.js\"",
    "lint:markdown": "markdownlint-cli2",
    "check": "npm run lint:markdown && npm run lint:html && npm run lint:css && npm run lint:js && npm run format:check"
  },
  "devDependencies": {
    "eslint": "10.7.0",
    "html-validate": "10.17.0",
    "markdownlint-cli2": "0.23.1",
    "prettier": "3.9.5",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0"
  },
  "engines": {
    "node": ">=22 <27"
  },
  "packageManager": "npm@10.9.3"
}
